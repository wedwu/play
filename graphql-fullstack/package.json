{
  "name": "graphql-fullstack",
  "private": true,
  "workspaces": ["server", "react-client"],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:react": "npm run dev --workspace=react-client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:react\"",
    "build": "npm run build --workspace=server && npm run build --workspace=react-client",
    "test": "npm run test --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
