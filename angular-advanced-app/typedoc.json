{
  "entryPoints": [
    "src/main.ts",
    "src/app/app.component.ts",
    "src/app/app.config.ts",
    "src/environments/environment.ts",
    "src/app/core/guards/auth.guard.ts",
    "src/app/core/helpers/utils.helper.ts",
    "src/app/core/interceptors/http.interceptor.ts",
    "src/app/core/models/base-entity.model.ts",
    "src/app/core/models/project.model.ts",
    "src/app/core/models/task.model.ts",
    "src/app/core/models/user.model.ts",
    "src/app/core/services/entity-state.service.ts",
    "src/app/core/services/notification.service.ts",
    "src/app/core/services/project.service.ts",
    "src/app/core/services/task.service.ts",
    "src/app/core/services/user.service.ts",
    "src/app/modules/dashboard/dashboard.component.ts",
    "src/app/modules/tasks/tasks.component.ts",
    "src/app/modules/users/users.component.ts",
    "src/app/shared/components/nav/nav.component.ts",
    "src/app/shared/components/toast/toast.component.ts",
    "src/app/shared/directives/directives.ts",
    "src/app/shared/pipes/pipes.ts"
  ],
  "out": "docs",
  "tsconfig": "tsconfig.docs.json",
  "name": "Angular Advanced App",
  "includeVersion": true,
  "readme": "README.md",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "categorizeByGroup": true,
  "sort": ["source-order"],
  "exclude": [
    "**/*.spec.ts",
    "**/node_modules/**"
  ]
}
