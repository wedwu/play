# ============================================
#   ROOT .gitignore
#   Covers: /react and /angular
# ============================================


# ─────────────────────────────────────────────
# DEPENDENCIES
# ─────────────────────────────────────────────
**/node_modules/
**/.pnp
**/.pnp.js
NOGIT.md
DOCUMENTATION/*

# ─────────────────────────────────────────────
# PRODUCTION BUILDS
# ─────────────────────────────────────────────
**/dist/
**/build/
**/out/


# ─────────────────────────────────────────────
# REACT SPECIFIC
# ─────────────────────────────────────────────
react/.cache/
react/.vite/
react/.eslintcache
react/coverage/


# ─────────────────────────────────────────────
# ANGULAR SPECIFIC
# ─────────────────────────────────────────────
angular/.angular/
angular/*.ngc.json
angular/.eslintcache
angular/coverage/
angular/.sass-cache/


# ─────────────────────────────────────────────
# ENVIRONMENT & SECRETS (both apps)
# ─────────────────────────────────────────────
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local


# ─────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*


# ─────────────────────────────────────────────
# TESTING
# ─────────────────────────────────────────────
**/coverage/
**/.nyc_output/
**/cypress/videos/
**/cypress/screenshots/


# ─────────────────────────────────────────────
# TYPESCRIPT
# ─────────────────────────────────────────────
**/*.tsbuildinfo


# ─────────────────────────────────────────────
# IDE & EDITOR
# ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# ─────────────────────────────────────────────
# OS FILES
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db


# ─────────────────────────────────────────────
# MISC
# ─────────────────────────────────────────────
**/*.pem
**/.vercel
**/.netlify
.history/*

/system-map/*